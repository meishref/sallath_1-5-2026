{% extends 'layouts/master.twig' %}

{% block title %}Plant Nursery Products{% endblock %}

{% block content %}
  {% set products = [
    { name: 'Majesty Palm', rating: '4.8', price: '55', stock: 1, image: 'https://images.unsplash.com/photo-1463320726281-696a485928c7?auto=format&fit=crop&w=800&q=80' },
    { name: 'Peperomia', rating: '4.6', price: '30', stock: 6, image: 'https://images.unsplash.com/photo-1485955900006-10f4d324d411?auto=format&fit=crop&w=800&q=80' },
    { name: 'Bird’s Nest Fern', rating: '4.7', price: '42', stock: 3, image: 'https://images.unsplash.com/photo-1501004318641-b39e6451bec6?auto=format&fit=crop&w=800&q=80' },
    { name: 'Aloe Vera', rating: '4.9', price: '25', stock: 10, image: 'https://images.unsplash.com/photo-1512428813834-c702c7702b78?auto=format&fit=crop&w=800&q=80' },
    { name: 'Snake Plant', rating: '4.8', price: '38', stock: 4, image: 'https://images.unsplash.com/photo-1459156212016-c812468e2115?auto=format&fit=crop&w=800&q=80' },
    { name: 'Monstera', rating: '4.9', price: '65', stock: 2, image: 'https://images.unsplash.com/photo-1520412099551-62b6bafeb5bb?auto=format&fit=crop&w=800&q=80' }
  ] %}

  <section class="product-page">
    <div class="product-page__container">
      {% include 'components/product/filters.twig' %}

      <main class="product-page__content">
        {% include 'partials/breadcrumb.twig' %}

        <div class="product-toolbar">
          <div class="product-toolbar__tags">
            <span class="filter-tag">Indoor Plants</span>
            <span class="filter-tag">Medium</span>
            <span class="filter-tag">Under $80</span>
          </div>

          <label class="sort-box">
            <span>Sort by:</span>
            <select class="js-sort-select">
              <option value="featured">Featured</option>
              <option value="price-low">Price: Low to High</option>
              <option value="price-high">Price: High to Low</option>
              <option value="rating">Top Rated</option>
            </select>
          </label>
        </div>

        <div class="products-grid">
          {% for product in products %}
            {% include 'components/product/product-card.twig' with { product: product } %}
          {% endfor %}
        </div>
      </main>
    </div>
  </section>
{% endblock %}
