<article class="product-card">
  <div class="product-card__image-wrap">
    {% if product.stock|default(0) == 1 %}
      <span class="product-card__badge">{{ 'only_one_stock'|trans }}</span>
    {% endif %}
    <img src="{{ product.image|default('https://images.unsplash.com/photo-1501004318641-b39e6451bec6?auto=format&fit=crop&w=800&q=80') }}" alt="{{ product.name }}" class="product-card__image">
    <button type="button" class="product-card__wishlist js-wishlist-btn" aria-label="Toggle wishlist">
      <span aria-hidden="true">❤</span>
    </button>
  </div>

  <div class="product-card__content">
    <h3 class="product-card__name">{{ product.name }}</h3>
    <p class="product-card__desc">{{ product.description|default('Healthy nursery plant ready for your home and office.') }}</p>
    <div class="product-card__rating" aria-label="{{ product.rating|default('4.7') }} out of 5 stars">
      <span>★★★★★</span>
      <small>({{ product.rating|default('4.7') }})</small>
    </div>
    <div class="product-card__price">${{ product.price }}</div>
    <button type="button" class="product-card__cart-btn">{{ 'add_to_cart'|trans }}</button>
  </div>
</article>
