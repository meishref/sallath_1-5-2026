<!DOCTYPE html>
<html lang="{{ locale|default('en') }}" dir="{{ locale == 'ar' ? 'rtl' : 'ltr' }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}{{ 'store_name'|trans }}{% endblock %}</title>
  {# Paths are relative to src/assets/ — see Twilight |asset filter (docs.salla.dev) #}
  <link rel="stylesheet" href="{{ 'styles/theme.css'|asset }}">
  <link rel="stylesheet" href="{{ 'styles/product-list.css'|asset }}">
  {% block styles %}{% endblock %}
</head>
<body>
  {% include 'components/header/header.twig' %}

  <main class="site-main">
    {% block content %}{% endblock %}
  </main>

  {% include 'components/footer/footer.twig' %}

  <script src="{{ 'js/theme.js'|asset }}"></script>
  <script src="{{ 'js/product-list.js'|asset }}"></script>
  {% block scripts %}{% endblock %}
</body>
</html>
